# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# base de données SQLite (231 Mo) + fichiers open data bruts.
# Trop volumineux pour Git/GitHub : reconstruits au déploiement via `npm run db:build`.
/data

# outils locaux Claude Code
/.claude

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python (scripts open data) : cache bytecode
__pycache__/
*.pyc
